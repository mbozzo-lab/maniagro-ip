generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  REFERENTE
  COLABORADOR
}

enum Tipo {
  ST
  SNP
}

enum Clasificacion {
  A
  B
  C
}

enum Estado {
  NO_INICIADO
  EN_PROCESO
  EN_REVISION
  FINALIZADO
  RETRASADO
  ANULADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
}

// ─── Auth models (NextAuth Prisma Adapter) ───────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ──────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  role          Role        @default(COLABORADOR)
  accounts      Account[]
  sessions      Session[]
  solicitudes   Solicitud[] @relation("Responsable")
  createdAt     DateTime    @default(now())
}

model Solicitud {
  id             Int            @id @default(autoincrement())
  numero         Int?
  proyecto       String
  driver         String?
  planta         String?
  linea          String?
  tipo           Tipo?
  clasificacion  Clasificacion?
  origen         String?
  prioridad      Prioridad      @default(MEDIA)
  criterio       String?
  detalle        String?
  activo         Boolean        @default(true)
  asignado       String?
  inversionEst   String?
  nroConsuman    String?
  fechaInicio    DateTime?
  avance         Float?
  estado         Estado         @default(NO_INICIADO)
  fechaFin       DateTime?
  comentario     String?
  gerencia       Boolean?
  im             Boolean?
  repasarCon     String?
  defGcia        String?
  definicionIM   String?
  revisar        Boolean        @default(false)
  responsable    User?          @relation("Responsable", fields: [responsableId], references: [id])
  responsableId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  actividades    Actividad[]
  obrasPE        ObraPE[]
}

model CriterioClasificacion {
  id               Int           @id @default(autoincrement())
  tipo             Tipo
  clasificacion    Clasificacion
  nombre           String
  definicion       String
  criterio1Label   String
  criterio1        String
  criterio2Label   String
  criterio2        String
  criterio3Label   String
  criterio3        String
  rolPruebas       String
  ejemplos         String
  clientesDirectos String

  @@unique([tipo, clasificacion])
}

model Actividad {
  id          Int        @id @default(autoincrement())
  solicitudId    Int?
  solicitud      Solicitud? @relation(fields: [solicitudId], references: [id])
  proyectoNombre String?
  detalle        String
  linea       String?
  responsable String
  estado      Estado     @default(NO_INICIADO)
  plazo       String?
  prioridad   Int?
  orden       Int?
  comentario  String?
  revisar     Boolean    @default(false)
  fecha       DateTime?
  sheetRow    Int?
  owner       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserPreferences {
  id              Int      @id @default(autoincrement())
  userId          String   @unique
  savedFilters    Json?
  dashboardLayout Json?
  notifications   Json?
  theme           String   @default("light")
  profilePicture  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ObjetivoConfig {
  id               Int      @id @default(autoincrement())
  mision           String   @db.Text
  objetivosAnuales Json
  informes         Json
  updatedBy        String
  updatedAt        DateTime @default(now())
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     String
  userName   String
  action     String
  entityType String
  entityId   Int
  entityName String
  changes    Json?
  timestamp  DateTime @default(now())
}

model DailyNote {
  id         Int      @id @default(autoincrement())
  userId     String
  userName   String
  fecha      DateTime
  hora       String?
  contenido  String
  completada Boolean  @default(false)
  prioridad  String   @default("MEDIA")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, fecha])
}

// ─── Minutas ─────────────────────────────────────────────────────────────────

enum EstadoMinuta {
  BORRADOR
  PUBLICADA
  ARCHIVADA
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

model Minuta {
  id            Int          @id @default(autoincrement())
  titulo        String
  tema          String
  fecha         DateTime     @db.Date
  horaInicio    String?
  horaFin       String?
  ubicacion     String?

  participantes Json
  ausentes      Json?

  objetivo  String  @db.Text
  temas     Json
  decisiones Json?
  notas     String? @db.Text

  tareas TareaMinuta[]

  estado        EstadoMinuta @default(BORRADOR)
  creadaPor     String
  creadorNombre String
  archivada     Boolean  @default(false)
  adjuntos      Json?

  fechaCreacion  DateTime @default(now())
  ultimaEdicion  DateTime @updatedAt

  @@index([tema, fecha])
  @@index([creadaPor])
  @@index([estado])
}

model TareaMinuta {
  id               Int            @id @default(autoincrement())
  minutaId         Int
  minuta           Minuta         @relation(fields: [minutaId], references: [id], onDelete: Cascade)

  descripcion      String         @db.Text
  responsable      String
  responsableEmail String?
  plazo            DateTime?      @db.Date
  prioridad        PrioridadTarea @default(MEDIA)
  estado           EstadoTarea    @default(PENDIENTE)

  comentarios     String?  @db.Text
  fechaCompletada DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([minutaId])
  @@index([responsable, estado])
  @@index([plazo])
}

// ─── Obras PE ─────────────────────────────────────────────────────────────────

enum EstadoObraPE {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  CANCELADA
  EN_ESPERA
}

model ObraPE {
  id                  Int          @id @default(autoincrement())
  responsable         String
  solicitudId         Int?
  solicitud           Solicitud?   @relation(fields: [solicitudId], references: [id])
  numeroSolicitud     String?
  detalle             String       @db.Text
  definicionesTomadas String?      @db.Text
  estado              EstadoObraPE @default(PENDIENTE)
  prioridad           String?
  plazo               DateTime?
  planta              String?
  observaciones       String?      @db.Text
  creadoPor           String
  creadorNombre       String
  fechaAlta           DateTime     @default(now())
  ultimaActualizacion DateTime     @updatedAt

  @@index([responsable])
  @@index([estado])
  @@index([solicitudId])
  @@index([fechaAlta])
  @@index([plazo])
}
